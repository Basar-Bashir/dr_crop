# =============================================================================
# Dr. Crop — backend secrets (copy this file to .env and fill in values)
# Copy:  cp .env.example .env   (PowerShell: Copy-Item .env.example .env)
# You can also put LLM_API_KEY in the repository ROOT .env (same folder as /frontend and /backend).
# Never commit .env — it is gitignored.
# =============================================================================

# --- Required for /predict (vision + synthesis) and smart /recommend ----------
# OpenAI API key (use ONE of these names — both work):
LLM_API_KEY=
# OPENAI_API_KEY=

# Chat Completions base URL (no trailing slash). OpenAI default:
LLM_BASE_URL=https://api.openai.com/v1

# Text model: recommendations + diagnosis synthesis
LLM_MODEL=gpt-4o-mini

# Vision model: must support image input on your provider (e.g. gpt-4o-mini, gpt-4o)
VISION_MODEL=gpt-4o-mini

# --- Optional: OpenWeatherMap (legacy demo helpers in app/services/weather_service.py) ---
OPENWEATHERMAP_API_KEY=

# --- Optional: web search RAG (better diagnosis context + treatment research) ---
EXA_API_KEY=

# --- Optional: Apify integration (see app/services/apify_service.py) ---------
APIFY_API_KEY=

# --- CORS: comma-separated origins (required for Vercel / non-localhost frontends) ---
# ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
