# =============================================================================
# Dr. Crop — frontend (copy to .env.local for local dev)
# Copy:  cp .env.example .env.local   (PowerShell: Copy-Item .env.example .env.local)
# Never use the NEXT_PUBLIC_ prefix for API keys — those are exposed in the browser.
# =============================================================================

# Backend API base URL (no trailing slash). Used for /predict and /recommend only.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Farm Copilot: Next.js API route /api/copilot (server-only, not sent to the browser) ---
# Required for the chat box. On Vercel: Project → Settings → Environment Variables
# (same names). Add for Production and Preview.
LLM_API_KEY=
# OPENAI_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
